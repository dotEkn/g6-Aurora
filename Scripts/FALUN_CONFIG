## R1 EDGE
conf t
hostname R1
no ip domain lookup
ip domain name aurora.local
ipv6 unicast-routing

! IPSEC VPN (KRYPTERING & REGLER)
crypto isakmp policy 1
 encryption aes
 hash sha256
 authentication pre-share
 group 14
 exit

! SSH konfigurering
! ip domain-name aurora-local
! crypto key generate rsa modulus 2048
! ip ssh version 2
! line vty 0 4
! transport input ssh
! login local
! exec-timeout 10 0
! exit

! aaa new-model
! Lokala användare
! username NAdmin privilege 15 secret 111
! username SAdmin privilege 7 secret 222
! aaa authentication login defualt local
! aaa authorization exec defualt local


crypto isakmp key AURORAKEY address 203.0.113.2
crypto ipsec transform-set IPCiscoSet esp-aes esp-sha256-hmac
 exit

!  ACL VPN: Från FALUN till GÄVLE
ip access-list extended AURORAVPN
 ! Falun Mgmt (199, 105) till Gävle Mgmt (99, 10, 15)
 permit ip 10.10.199.0 0.0.0.255 10.10.99.0 0.0.0.255
 permit ip 10.10.199.0 0.0.0.255 10.10.10.0 0.0.0.255
 permit ip 10.10.199.0 0.0.0.255 10.10.15.0 0.0.0.255
 permit ip 10.10.105.0 0.0.0.255 10.10.99.0 0.0.0.255
 ! Falun Server (140) till Gävle Server/DMZ (40, 5)
 permit ip 10.10.140.0 0.0.0.255 10.10.40.0 0.0.0.255
 permit ip 10.10.140.0 0.0.0.255 10.10.5.0 0.0.0.255
 permit ip 10.10.140.0 0.0.0.255 172.16.30.0 0.0.0.255
 ! Falun Personal/Analys (172.16.110, 172.16.120) till Gävle Server (40)
 permit ip 172.16.110.0 0.0.0.255 10.10.40.0 0.0.0.255
 permit ip 172.16.120.0 0.0.0.255 10.10.40.0 0.0.0.255
 ! Falun Personal/Analys till Gävle Kontor (172.16.30)
 permit ip 172.16.110.0 0.0.0.255 172.16.30.0 0.0.0.255
 permit ip 172.16.120.0 0.0.0.255 172.16.30.0 0.0.0.255
 permit ip 172.16.110.0 0.0.0.255 10.10.5.0 0.0.0.255
 permit ip 172.16.120.0 0.0.0.255 10.10.5.0 0.0.0.255 
 ! R1-R2-R3 länknät till Gävle
 permit ip 10.10.1.0 0.0.0.255 10.10.99.0 0.0.0.255
 exit

crypto map AURORAMAP 5 ipsec-isakmp
 set peer 203.0.113.2
 set transform-set IPCiscoSet
 match address AURORAVPN
 exit

! BRANDVÄGG & NAT-LISTOR
ip access-list extended FE-NAT-EXT
 ! --- NAT-UNDANTAG FÖR VPN (Deny = Gör INGEN NAT) ---
 deny ip 10.10.0.0 0.0.255.255 10.10.0.0 0.0.255.255
 deny ip 10.10.0.0 0.0.255.255 172.16.0.0 0.15.255.255
 deny ip 172.16.0.0 0.15.255.255 10.10.0.0 0.0.255.255
 deny ip 172.16.0.0 0.15.255.255 172.16.0.0 0.15.255.255
 ! --- TILLÅT NAT TILL INTERNET ---
 permit ip 172.16.110.0 0.0.0.255 any
 permit ip 172.16.120.0 0.0.0.255 any
 permit ip 10.10.115.0 0.0.0.255 any
 permit ip 10.10.125.0 0.0.0.255 any
 permit ip 10.10.140.0 0.0.0.255 any
 permit ip 10.10.199.0 0.0.0.255 any
 permit ip 10.10.1.0 0.0.0.255 any
 exit

! 2. Brandväggen mot Internet
ip access-list extended HK-EDGE-IN
 ! Tillåt VPN-tunneln från Falun
 permit udp host 203.0.113.2 host 203.0.113.10 eq isakmp
 permit esp host 203.0.113.2 host 203.0.113.10
 ! Tillåt normal internet-svarstrafik och webb till DMZ
 permit tcp any any established
 permit icmp any any echo-reply
 permit icmp any any time-exceeded
 permit icmp any any unreachable
 permit tcp any host 203.0.113.2 eq 80
 ! Blockera fultrafik
 deny ip any 10.10.0.0 0.0.255.255
 deny ip any 172.16.0.0 0.0.255.255
 deny ip any any log
 exit

interface g0/0
 description WAN_TO_ISP
 ip address 203.0.113.10 255.255.255.252
 ipv6 address 2001:db8:abcd:2::8/127
 ipv6 address FE80::1 link-local
 crypto map AURORAMAP
 ip nat outside
 no shut

interface g0/1
 desc TO_R2
 ip address 10.10.100.1 255.255.255.252
 ipv6 address 2001:DB8:ABCD:101::1/64
 ipv6 address FE80::1:1 link-local
 ip nat inside
 no shut

interface g0/2
 desc TO_R3
 ip address 10.10.100.5 255.255.255.252
 ipv6 address 2001:DB8:ABCD:103::1/64
 ipv6 address FE80::1:2 link-local
 ip nat inside
 no shut

ip route 0.0.0.0 0.0.0.0 203.0.113.9
no ip nat inside source list FE-NAT interface G0/0 overload
ip nat inside source list FE-NAT-EXT interface G0/0 overload

## ===== ACL SECTION =====

! NTP ACL (allow only R2 & R3)
ip access-list standard NTP-INTERNAL
 permit 10.10.100.2       ! R2 CORE
 permit 10.10.100.6       ! R3 CORE
 deny any
exit

## ===== NTP SETTINGS =====
clock timezone CET 1
clock summer-time CEST recurring

! Sync with external servers
ntp server 0.se.pool.ntp.org prefer
ntp server 1.se.pool.ntp.org

! Fallback local source if internet is down
ntp master 4

! Restrict who can query NTP
ntp access-group serve-only NTP-INTERNAL
ntp access-group query-only NTP-INTERNAL

! ROUTES TILL GÄVLE HK
ip route 10.10.5.0 255.255.255.0 203.0.113.9
ip route 10.10.10.0 255.255.255.0 203.0.113.9
ip route 10.10.15.0 255.255.255.0 203.0.113.9
ip route 10.10.20.0 255.255.255.0 203.0.113.9
ip route 10.10.25.0 255.255.255.0 203.0.113.9
ip route 10.10.30.0 255.255.255.0 203.0.113.9
ip route 10.10.35.0 255.255.255.0 203.0.113.9
ip route 10.10.40.0 255.255.255.0 203.0.113.9
ip route 10.10.99.0 255.255.255.0 203.0.113.9
ip route 172.16.20.0 255.255.255.0 203.0.113.9
ip route 172.16.25.0 255.255.255.0 203.0.113.9
ip route 172.16.30.0 255.255.255.0 203.0.113.9
ip route 172.16.35.0 255.255.255.0 203.0.113.9

ipv6 route ::/0 2001:db8:abcd:2::9

router ospf 10
 router-id 1.1.1.1
 passive-interface default
 no passive-interface g0/1
 no passive-interface g0/2
 network 10.10.100.0 0.0.0.3 area 0
 network 10.10.100.4 0.0.0.3 area 0
 default-information originate always

ipv6 router ospf 10
 router-id 1.1.1.1
 default-information originate
exit

 interface g0/1
 ipv6 ospf 10 area 0
 interface g0/2
 ipv6 ospf 10 area 0

## R2 CORE

conf t
hostname R2
no ip domain lookup
ip domain name aurora.local
ipv6 unicast-routing

! SSH konfigurering
! ip domain-name aurora-local
! crypto key generate rsa modulus 2048
! ip ssh version 2
! line vty 0 4
! transport input ssh
! login local
! exec-timeout 10 0
! exit

! aaa new-model
! Lokala användare
! username NAdmin privilege 15 secret 111
! username SAdmin privilege 7 secret 222
! aaa authentication login defualt local
! aaa authorization exec defualt local

! ACL för att isolera IoT-sensorerna
ip access-list extended IOT-RESTRICT
 ! tillåter trafik VLAN 155 till Backend-Servern
 permit ip host 10.10.155.21 host 10.10.140.40
 permit ip host 10.10.155.22 host 10.10.140.40
 permit ip host 10.10.155.23 host 10.10.140.40
 permit ip host 10.10.155.24 host 10.10.140.40
 ! blockerar all annam trafik och loggar forsoken
 deny ip any any log
exit

ip access-list extended ISOLERA-VLAN125
! Håller Router uppdaterat så den ej blockerar vid senare tillfälle.
 permit udp any any eq bootps
! Blockerar att nå interna addressrymder
 deny ip any 10.0.0.0 0.255.255.255
 deny ip any 172.16.0.0 0.15.255.255
 deny ip any 192.168.0.0 0.0.255.255
! Ska tillåta annan trafik ut mot internet
 permit ip any any
exit

! Exkludera DHCP adresser
ip dhcp excluded-address 172.16.110.1 172.16.110.50
ip dhcp excluded-address 172.16.110.201 172.16.110.254
ip dhcp excluded-address 10.10.115.1 10.10.115.50
ip dhcp excluded-address 10.10.115.201 10.10.115.254
ip dhcp excluded-address 172.16.120.1 172.16.120.50
ip dhcp excluded-address 172.16.120.201 172.16.120.254
ip dhcp excluded-address 10.10.125.1 10.10.125.50
ip dhcp excluded-address 10.10.125.201 10.10.125.254
ip dhcp excluded-address 10.10.135.1 10.10.135.50
ip dhcp excluded-address 10.10.135.201 10.10.135.254
ip dhcp excluded-address 10.10.150.1 10.10.150.50
ip dhcp excluded-address 10.10.150.201 10.10.150.254

! DHCP pool för VLAN 110
ip dhcp pool VLAN110_PERSONAL
 network 172.16.110.0 255.255.255.0
 default-router 172.16.110.1
 dns-server 8.8.8.8

! DHCP pool för VLAN 115
ip dhcp pool VLAN115_PERSONAL_AP
 network 10.10.115.0 255.255.255.0
 default-router 10.10.115.1
 dns-server 8.8.8.8

! DHCP pool för VLAN 120
ip dhcp pool VLAN120_ANALYS
 network 172.16.120.0 255.255.255.0
 default-router 172.16.120.1
 dns-server 8.8.8.8

! DHCP pool för VLAN 125
ip dhcp pool VLAN125_ANALYS_AP
 network 10.10.125.0 255.255.255.0
 default-router 10.10.125.1
 dns-server 8.8.8.8

! DHCP pool för VLAN 135
ip dhcp pool VLAN135_TEST_AP
 network 10.10.135.0 255.255.255.0
 default-router 10.10.135.1
 dns-server 8.8.8.8

! DHCP pool för VLAN 150
ip dhcp pool VLAN150_SENSOR_AP
 network 10.10.150.0 255.255.255.0
 default-router 10.10.150.1
 dns-server 8.8.8.8

interface g0/0/0
 ip address 10.10.100.2 255.255.255.252
 ipv6 address 2001:DB8:ABCD:101::2/64
 ipv6 address FE80::2:1 link-local
 no shut

