## SW1

conf t
hostname SW1
no ip domain-lookup
vtp mode transparent
spanning-tree mode rapid-pvst

vlan 110 
 name PERSONAL 
vlan 115 
 name PERSONAL_WIFI
vlan 120
 name ANALYS
vlan 125
 name ANALYS_WIFI
vlan 135
 name TEST_WIFI
vlan 140
 name SERVER
vlan 150
 name SENSOR_AP_MGMT
vlan 155
 name SENSOR_DATA
vlan 199
 name MGMT
vlan 999
 name SVARTHÅL

interface Vlan199
 ip address 10.10.199.11 255.255.255.0
 no shut
ip default-gateway 10.10.199.1

! STP root primary
spanning-tree vlan 110,115,120,125,130,135,140,150,155,199 root primary

! Trunk till R2
interface Gi1/0/15
 description TRUNK_TO_R2-FE_G0/0/1
 switchport mode trunk
 switchport trunk native vlan 999
 switchport trunk allowed vlan 110,115,120,125,130,135,140,150,155,199

! Servers VLAN 140
interface Gi1/0/16
 description SERVERS_VLAN140
 switchport mode access
 switchport access vlan 140
 spanning-tree portfast
 spanning-tree bpduguard enable

! OANVÄNDA PORTAR
interface range Gi1/0/1-14, Gi1/0/17-20, Gi1/0/25-28
 description SVARTHÅL
 switchport mode access
 switchport access vlan 999
 shutdown

! ===== Po12 till SW2 (Gi1/0/21-22) =====
interface range Gi1/0/21-22
 description LACP_TO_SW2
 switchport mode trunk
 switchport trunk native vlan 999
 switchport trunk allowed vlan 110,115,120,125,130,135,140,150,155,199
 channel-group 1 mode active

interface Port-channel1
 description PO12_TO_SW2
 switchport mode trunk
 switchport trunk native vlan 999
 switchport trunk allowed vlan 110,115,120,125,130,135,140,150,155,199

! ===== Po13 till SW3 (Gi1/0/23-24) =====
interface range Gi1/0/23-24
 description LACP_TO_SW3
 switchport mode trunk
 switchport trunk native vlan 999
 switchport trunk allowed vlan 110,115,120,125,130,135,140,150,155,199
 channel-group 2 mode active

interface Port-channel2
 description PO13_TO_SW3
 switchport mode trunk
 switchport trunk native vlan 999
 switchport trunk allowed vlan 110,115,120,125,130,135,140,150,155,199

end

## SW2

conf t
hostname SW2
no ip domain-lookup
vtp mode transparent
spanning-tree mode rapid-pvst

vlan 110 
 name PERSONAL 
vlan 115 
 name PERSONAL_WIFI
vlan 120
 name ANALYS
vlan 125
 name ANALYS_WIFI
vlan 135
 name TEST_WIFI
vlan 140
 name SERVER
vlan 150
 name SENSOR_AP_MGMT
vlan 155
 name SENSOR_DATA
vlan 199
 name MGMT
vlan 999
 name SVARTHÅL

