 ip address 10.10.199.12 255.255.255.0
 no shut
ip default-gateway 10.10.199.1

spanning-tree vlan 110,115,120,135,140,150,155,199 root secondary

! Trunk till R3
interface Gi1/0/15
 description TRUNK_TO_R3-FE_G0/0/1
 switchport mode trunk
 switchport trunk native vlan 999
 switchport trunk allowed vlan 110,115,120,125,130,135,140,150,155,199

! Personal PC VLAN110
interface range Gi1/0/1-14
 description PERSONAL_PC
 switchport mode access
 switchport access vlan 110
 spanning-tree portfast
 spanning-tree bpduguard enable

! OANVÄNDA PORTAR
interface range Gi1/0/17-20, Gi1/0/25-28
 description SVARTHÅL
 switchport mode access
 switchport access vlan 999
 shutdown

! AP1 VLAN115
interface Gi1/0/16
 description AP1_PERSONAL_WIFI
 switchport mode access
 switchport access vlan 115
 spanning-tree portfast
 spanning-tree bpduguard enable

! ===== Po12 till SW1 (Gi1/0/23-24) =====
interface range Gi1/0/23-24
 description LACP_TO_SW1
 switchport mode trunk
 switchport trunk native vlan 999
 switchport trunk allowed vlan 110,115,120,125,130,135,140,150,155,199
 channel-group 1 mode active

interface Port-channel1
 description PO12_TO_SW1
 switchport mode trunk
 switchport trunk native vlan 999
 switchport trunk allowed vlan 110,115,120,125,130,135,140,150,155,199

! ===== Po24 till SW4 (Gi1/0/21-22) =====
interface range Gi1/0/21-22
 description LACP_TO_SW4
 switchport mode trunk
 switchport trunk native vlan 999
 switchport trunk allowed vlan 110,115,120,125,130,135,140,150,155,199
 channel-group 3 mode active

interface Port-channel3
 description PO24_TO_SW4
 switchport mode trunk
 switchport trunk native vlan 999
 switchport trunk allowed vlan 110,115,120,125,130,135,140,150,155,199

