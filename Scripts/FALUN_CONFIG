! VLAN 140 Server
interface GigabitEthernet0/0/1.140
 encapsulation dot1Q 140
 ip address 10.10.140.2 255.255.255.0
 standby 140 ip 10.10.140.1
 standby 140 priority 110
 standby 140 preempt

! VLAN 150 Sensor AP mgmt
interface GigabitEthernet0/0/1.150
 encapsulation dot1Q 150
 ip address 10.10.150.2 255.255.255.0
 standby 150 ip 10.10.150.1
 standby 150 priority 110
 standby 150 preempt
 ip helper-address 10.10.140.41

! VLAN 155 Sensor data
interface GigabitEthernet0/0/1.155
 encapsulation dot1Q 155
 ip address 10.10.155.2 255.255.255.0
 standby 155 ip 10.10.155.1
 standby 155 priority 110
 standby 155 preempt
 ip helper-address 10.10.140.41

router ospf 10
 router-id 2.2.2.2
 passive-interface default
 no passive-interface GigabitEthernet0/0/0
 no passive-interface GigabitEthernet0/0/2
 network 10.10.1.0 0.0.0.3 area 0
 network 10.10.1.8 0.0.0.3 area 0
 network 10.10.199.0 0.0.0.255 area 0
 network 172.16.110.0 0.0.0.255 area 0
 network 172.16.120.0 0.0.0.255 area 0
 network 172.16.130.0 0.0.0.255 area 0
 network 10.10.115.0 0.0.0.255 area 0
 network 10.10.125.0 0.0.0.255 area 0
 network 10.10.135.0 0.0.0.255 area 0
 network 10.10.140.0 0.0.0.255 area 0
 network 10.10.150.0 0.0.0.255 area 0
 network 10.10.155.0 0.0.0.255 area 0

