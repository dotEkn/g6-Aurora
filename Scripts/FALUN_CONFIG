clock summer-time CEST recurring
ntp source GigabitEthernet0/0/0
ntp server 10.10.100.5
ntp access-group serve-only NTP-MGMT
ntp access-group query-only NTP-MGMT
end


## SW1

conf t
hostname SW1
no ip domain-lookup
vtp mode transparent
spanning-tree mode rapid-pvst

! SSH konfigurering
! ip domain-name aurora-local
! crypto key generate rsa modulus 2048
! ip ssh version 2
! line vty 0 4
! transport input ssh
! login local
! exec-timeout 10 0
! exit

! aaa new-model
! Lokala användare
! username NAdmin privilege 15 secret 111
! username SAdmin privilege 7 secret 222
! aaa authentication login defualt local
! aaa authorization exec defualt local

vlan 105
 name Management
vlan 110 
 name PERSONAL 
vlan 115 
 name PERSONAL_AP
vlan 120
 name ANALYS
vlan 125
 name ANALYS_AP
vlan 135
 name TEST_AP
vlan 140
 name SERVER
vlan 150
 name SENSOR_AP_MGMT
vlan 155
 name SENSOR_DATA
vlan 199
 name MANAGEMENT
vlan 999
 name SVARTHÅL

! Global DHCP snooping inställningar
ip dhcp snooping
ip dhcp snooping vlan 110,115,120,125
no ip dhcp snooping information option
ip arp inspection vlan 110,115,120,125

interface Vlan199
 ip address 10.10.199.11 255.255.255.0
 ipv6 address 2001:DB8:ABCD:199::11/64
 ipv6 address FE80::11 link-local
 no shut
exit
ip default-gateway 10.10.199.1

! STP root primary
spanning-tree vlan 110,115,120,125,135,140,150,155,199 root primary

! Trunk till R2 (Trusted port för DHCP)
interface Gi1/0/15
 description TRUNK_TO_R2-FE_G0/0/1
 switchport mode trunk
 switchport trunk native vlan 199
 switchport trunk allowed vlan 105,110,115,120,125,135,140,150,155,199
ip dhcp snooping trust
 ip arp inspection trust
exit

! Servers VLAN 140
interface range Gi1/0/1-3
 description SERVERS_VLAN140
 switchport mode access
 switchport access vlan 140
 spanning-tree portfast
 spanning-tree bpduguard enable
 switchport port-security
 switchport port-security maximum 3
 switchport port-security violation restrict
 switchport port-security mac-address sticky
exit

! OANVÄNDA PORTAR
interface range Gi1/0/4-14, Gi1/0/17-20, Gi1/0/25-28
 description SVARTHÅL
 switchport mode access
 switchport access vlan 999
 shutdown

! ===== Po12 till SW2 (Gi1/0/21-22) =====
interface range Gi1/0/21-22
 description LACP_TO_SW2
 switchport mode trunk
 switchport trunk native vlan 199
 switchport trunk allowed vlan 105,110,115,120,125,135,140,150,155,199
 channel-group 1 mode active
exit

interface Port-channel1
 description PO12_TO_SW2
 switchport mode trunk
 switchport trunk native vlan 199
 switchport trunk allowed vlan 105,110,115,120,125,135,140,150,155,199
 ip dhcp snooping trust
 ip arp inspection trust
exit

! ===== Po13 till SW3 (Gi1/0/23-24) =====
interface range Gi1/0/23-24
 description LACP_TO_SW3
 switchport mode trunk
 switchport trunk native vlan 199
 switchport trunk allowed vlan 105,110,115,120,125,135,140,150,155,199
 channel-group 2 mode active
exit

interface Port-channel2
 description PO13_TO_SW3
 switchport mode trunk
 switchport trunk native vlan 199
 switchport trunk allowed vlan 105,110,115,120,125,135,140,150,155,199
 ip dhcp snooping trust
 ip arp inspection trust
exit

## ===== NTP SETTINGS =====
clock timezone CET 1
clock summer-time CEST recurring
ntp source Vlan199
ntp server 10.10.199.1
end

