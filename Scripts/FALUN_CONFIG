 ip helper-address 10.10.140.41
 ip access-group IOT-RESTRICT in

router ospf 10
 router-id 3.3.3.3
 passive-interface default
 no passive-interface GigabitEthernet0/0/0
 no passive-interface GigabitEthernet0/0/1
 network 10.10.100.4 0.0.0.3 area 0
 network 10.10.199.0 0.0.0.255 area 0
 network 172.16.110.0 0.0.0.255 area 0
 network 172.16.120.0 0.0.0.255 area 0
 network 10.10.115.0 0.0.0.255 area 0
 network 10.10.125.0 0.0.0.255 area 0
 network 10.10.135.0 0.0.0.255 area 0
 network 10.10.140.0 0.0.0.255 area 0
 network 10.10.150.0 0.0.0.255 area 0
 network 10.10.155.0 0.0.0.255 area 0

ipv6 route ::/0 2001:db8:abcd:3::1

ipv6 router ospf 10
 router-id 3.3.3.3
 default-information originate
 exit

 interface g0/0/0
 ipv6 ospf 10 area 0
 interface g0/0/1.199
 ipv6 ospf 10 area 0
 interface g0/0/1.110
 ipv6 ospf 10 area 0
 interface g0/0/1.115
 ipv6 ospf 10 area 0
 interface g0/0/1.120
 ipv6 ospf 10 area 0
