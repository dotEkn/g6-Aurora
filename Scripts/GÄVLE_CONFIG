# CONFIGS GÄVLE HK
# ROUTER

## R1
conf t
hostname R1-HK
no ip domain lookup
ip domain name aurora.local
ipv6 unicast-routing

! SSH konfigurering
! ip domain-name aurora-local
! crypto key generate rsa modulus 2048
! ip ssh version 2
! line vty 0 4
! transport input ssh
! login local
! exec-timeout 10 0
! exit

! aaa new-model
! Lokala användare
! username NAdmin privilege 15 secret 111
! username SAdmin privilege 7 secret 222
! aaa authentication login default local
! aaa authorization exec default local

! ZPF
zone security INSIDE
zone security OUTSIDE
zone security DMZ
 exit

! VPN 
conf t

! IPsec inställningar
crypto isakmp policy 1
 encryption aes
 hash sha256
 authentication pre-share
 group 14
 exit

crypto isakmp key AURORAKEY address 203.0.113.10

crypto ipsec transform-set IPCiscoSet esp-aes esp-sha256-hmac
 exit

! Komplett ACL: SPEGELVÄND! Från GÄVLE till FALUN
ip access-list extended AURORAVPN
 ! Gävle Mgmt (99, 10, 15) till Falun Mgmt (199, 105)
 permit ip 10.10.99.0 0.0.0.255 10.10.199.0 0.0.0.255
 permit ip 10.10.10.0 0.0.0.255 10.10.199.0 0.0.0.255
 permit ip 10.10.15.0 0.0.0.255 10.10.199.0 0.0.0.255
 permit ip 10.10.99.0 0.0.0.255 10.10.105.0 0.0.0.255
 ! Gävle Server/DMZ (40, 5) till Falun Server (140)
 permit ip 10.10.40.0 0.0.0.255 10.10.140.0 0.0.0.255
 permit ip 10.10.5.0 0.0.0.255 10.10.140.0 0.0.0.255
 ! Gävle Server (40) till Falun Personal/Analys (172.16.110, 172.16.120)
 permit ip 10.10.40.0 0.0.0.255 172.16.110.0 0.0.0.255
 permit ip 10.10.40.0 0.0.0.255 172.16.120.0 0.0.0.255
 permit ip 172.16.30.0 0.0.0.255 10.10.140.0 0.0.0.255
 ! Gävle Kontor (172.16.30) till Falun Personal/Analys
 permit ip 172.16.30.0 0.0.0.255 172.16.110.0 0.0.0.255
 permit ip 172.16.30.0 0.0.0.255 172.16.120.0 0.0.0.255
 ! R1-R2-R3 länknät från Gävle
 permit ip 10.10.99.0 0.0.0.255 10.10.1.0 0.0.0.255
 ! Tillåt Gävle DMZ (5) att prata med Falun Personal/Analys (110, 120)
 permit ip 10.10.5.0 0.0.0.255 172.16.110.0 0.0.0.255
 permit ip 10.10.5.0 0.0.0.255 172.16.120.0 0.0.0.255
 exit

ip access-list extended HK-EDGE-IN
 ! Tillåt VPN från Falun
 permit udp host 203.0.113.2 host 203.0.113.10 eq isakmp
 permit esp host 203.0.113.2 host 203.0.113.10
 ! Tillåt normal internet-svarstrafik
 permit tcp any any established
 permit icmp any any echo-reply
 permit icmp any any time-exceeded
 permit icmp any any unreachable
 ! Blockera fultrafik utifrån
 deny ip any 10.0.0.0 0.255.255.255
 deny ip any 172.16.0.0 0.15.255.255
exit

ip access-list extended GUEST-INTERNET-ONLY
 deny ip 10.10.25.0 0.0.0.255 10.10.0.0 0.0.255.255
 deny ip 10.10.25.0 0.0.0.255 172.16.0.0 0.15.255.255
 permit ip 10.10.25.0 0.0.0.255 any
exit

! Crypto map
crypto map AURORAMAP 5 ipsec-isakmp
 set peer 203.0.113.10
 set transform-set IPCiscoSet
 match address AURORAVPN
 exit

! ZPF CLASS MAPS
class-map type inspect match-any CM-INSIDE-OUT
 match protocol http
 match protocol https
 match protocol dns
 match protocol icmp
 match protocol isakmp
 match protocol ipsec

class-map type inspect match-any CM-INSIDE-DMZ
 match protocol ftp
 match protocol icmp

class-map type inspect match-any CM-OUTSIDE-DMZ
 match protocol http

class-map type inspect match-any CM-VPN
 match access-group name AURORAVPN
exit

! ZPF POLICY MAPS
policy-map type inspect PM-INSIDE-OUT
 class CM-INSIDE-OUT
  inspect
 class class-default
  drop

policy-map type inspect PM-INSIDE-DMZ
 class type inspect CM-INSIDE-DMZ
  inspect
 class class-default
  drop

policy-map type inspect PM-OUTSIDE-DMZ
 class CM-VPN
  inspect
 class CM-OUTSIDE-DMZ
  inspect
 class class-default
  drop
 exit

! ZPF ZONE PAIRS
zone-pair security ZP-INSIDE-OUT source INSIDE destination OUTSIDE
 service-policy type inspect PM-INSIDE-OUT

zone-pair security ZP-INSIDE-DMZ source INSIDE destination DMZ
 service-policy type inspect PM-INSIDE-DMZ

zone-pair security ZP-OUTSIDE-DMZ source OUTSIDE destination DMZ
 service-policy type inspect PM-OUTSIDE-DMZ
 exit

! NAT-listan
ip access-list extended HK-NAT-EXT

 ! --- NAT-UNDANTAG FÖR VPN (Deny = Gör INGEN NAT) ---
 ! Detta stoppar NAT från att stjäla trafik som går mellan Falun och Gävle
 deny ip 10.10.0.0 0.0.255.255 10.10.0.0 0.0.255.255
 deny ip 10.10.0.0 0.0.255.255 172.16.0.0 0.15.255.255
 deny ip 172.16.0.0 0.15.255.255 10.10.0.0 0.0.255.255
 deny ip 172.16.0.0 0.15.255.255 172.16.0.0 0.15.255.255

 ! --- TILLÅT NAT TILL INTERNET (Permit = Översätt till publik IP) ---
 ! Här lägger vi in exakt samma nätverk som du hade i din gamla access-list 5
 permit ip 10.10.5.0 0.0.0.255 any
 permit ip 10.10.40.0 0.0.0.255 any
 permit ip 10.10.99.0 0.0.0.255 any
 permit ip 172.16.20.0 0.0.0.255 any
 permit ip 172.16.25.0 0.0.0.255 any
 permit ip 172.16.30.0 0.0.0.255 any
 permit ip 172.16.35.0 0.0.0.255 any
 exit

! WAN
interface GigabitEthernet0/0/0
 description WAN_TO_ISP
 ip address 203.0.113.2 255.255.255.252
 ipv6 address 2001:db8:abcd:1::0/127
 ipv6 address FE80::1 link-local
 crypto map AURORAMAP
 ip access-group HK-EDGE-IN in
 ip nat outside
 no shut

! ZPF
 zone-member security OUTSIDE

! --- IP Routes ---
ip route 0.0.0.0 0.0.0.0 203.0.113.1
ip route 172.16.0.0 255.255.0.0 203.0.113.1
ip route 10.10.100.0 255.255.255.0 203.0.113.1
ip route 10.10.140.0 255.255.255.0 203.0.113.1


! NATIVE (VLAN 99 via SW1)
interface GigabitEthernet0/0/1
 description NATIVE_VLAN_99
 ip address 10.10.99.1 255.255.255.0
 ipv6 address 2001:DB8:ABCD:99::1/64
 ipv6 address FE80::1A link-local
 ip nat inside
 no shut

! ZPF
 zone-member security INSIDE

! DMZ VLAN 5
interface GigabitEthernet0/0/1.5
 description DMZ_VLAN5
 encapsulation dot1Q 5
 ip address 10.10.5.1 255.255.255.0
 ipv6 address 2001:DB8:ABCD:5::1/64
 ipv6 address FE80::1B link-local
 ipv6 ospf 5 area 0
 ip nat inside
 no shut

! ZPF
 zone-member security DMZ

! MANAGEMENT_TRANSIT VLAN 10
interface GigabitEthernet0/0/1.10
 description MANAGEMENT_TRANSIT_VLAN10
 encapsulation dot1Q 10
 ip address 10.10.10.1 255.255.255.0
 ipv6 address 2001:DB8:ABCD:10::1/64
 ipv6 address FE80::1C link-local
 no shut

! ZPF
 zone-member security INSIDE

! NAT-Funktionen
no ip nat inside source list 5 interface GigabitEthernet0/0/0 overload
ip nat inside source list HK-NAT-EXT interface GigabitEthernet0/0/0 overload

! OSPF mot interna routrar
router ospf 5
 router-id 1.1.1.1
 passive-interface default
 no passive-interface GigabitEthernet0/0/1
 network 10.10.5.0 0.0.0.255 area 0
 network 10.10.10.0 0.0.0.255 area 0
 network 10.10.99.0 0.0.0.255 area 0
 default-information originate
end

## R2
