# CONFIGS GÄVLE HK
# ROUTER

## R1
conf t
hostname R1-HK
no ip domain lookup
ip domain name aurora.local
ipv6 unicast-routing

ip access-list extended HK-EDGE-IN

! --- Tillåt svarstrafik (stateful-liknande beteende) ---
permit tcp any any established
permit icmp any any echo-reply
permit icmp any any time-exceeded
permit icmp any any unreachable

! --- Tillåt HTTP till DMZ (publik IP på R1) ---
permit tcp any host 203.0.113.2 eq 80

! --- Blockera Internet till interna privata nät ---
deny ip any 10.10.0.0 0.0.255.255
deny ip any 172.16.0.0 0.0.255.255

! --- Blockera allt annat ---
deny ip any any log

exit

! WAN
interface GigabitEthernet0/0/0
 description WAN_TO_ISP
 ip address 203.0.113.2 255.255.255.252
 ipv6 address autoconfig default
 ip access-group HK-EDGE-IN in
 ip nat outside
 no shut

! --- IP Routes, Statiskt, Falun 172 och 10 nät. ---
ip route 0.0.0.0 0.0.0.0 203.0.113.1
ip route 172.16.0.0 255.255.0.0 203.0.113.1 
ip route 10.10.0.0 255.255.0.0 203.0.113.1

! TRANSIT (VLAN 99 via SW1)
interface GigabitEthernet0/0/1
 description TRANSIT_TO_SW1
 ip address 10.10.99.1 255.255.255.0
 ipv6 address 2001:DB8:ABCD:99::1/64
 ipv6 address FE80::1A link-local
 ip nat inside
 no shut

! DMZ VLAN 10
interface GigabitEthernet0/0/1.10
 description DMZ_VLAN10
 encapsulation dot1Q 10
 ip address 10.10.10.1 255.255.255.0
 ipv6 address 2001:DB8:ABCD:10::1/64
 ipv6 address FE80::1B link-local
 ipv6 ospf 10 area 0
 ip nat inside
 no shut

! OSPF mot interna routrar
router ospf 10
 router-id 1.1.1.1
 passive-interface default
 no passive-interface GigabitEthernet0/0/1
 network 10.10.99.0 0.0.0.255 area 0
 default-information originate

! NAT för interna nät
access-list 10 permit 10.10.10.0 0.0.0.255
access-list 10 permit 10.10.40.0 0.0.0.255
access-list 10 permit 10.10.99.0 0.0.0.255
access-list 10 permit 172.16.20.0 0.0.0.255
access-list 10 permit 172.16.25.0 0.0.0.255
access-list 10 permit 172.16.30.0 0.0.0.255
access-list 10 permit 172.16.35.0 0.0.0.255

ip nat inside source list 10 interface GigabitEthernet0/0/0 overload

! Port-forward HTTP till webbserver i DMZ
ip nat inside source static tcp 10.10.10.10 80 interface GigabitEthernet0/0/0 80

end


## R2
conf t
hostname R2-HK
no ip domain lookup
ip domain name aurora.local
ipv6 unicast-routing

! ====== TRUNK till SW1 (bär VLAN 5 + VLAN 10) ======
interface GigabitEthernet0/0/0
 description TRUNK_TO_SW1
 no ip address
 no shut

interface GigabitEthernet0/0/0.99
 encapsulation dot1Q 99
 ip address 10.10.99.2 255.255.255.0
 ipv6 address 2001:DB8:ABCD:99::2/64
 ipv6 address FE80::2A link-local
 ipv6 ospf 10 area 0
 

interface GigabitEthernet0/0/0.10
 encapsulation dot1Q 10
 ip address 10.10.10.2 255.255.255.0
 ipv6 address 2001:DB8:ABCD:10::2/64
 ipv6 address FE80::2B link-local
 standby 10 ip 10.10.10.3
 standby 10 ipv6 FE80::1
 standby 10 ipv6 2001:DB8:ABCD:10::1
 standby 10 priority 110
 standby 10 preempt
 ipv6 ospf 10 area 0

! ====== TRUNK till SW2 (campus VLAN) ======
interface GigabitEthernet0/0/1
 description TRUNK_TO_SW2
 no ip address
 no shut

interface GigabitEthernet0/0/1.20
