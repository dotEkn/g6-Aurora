# SWITCHAR

## SW1
conf t
hostname SW1-HK
no ip domain-lookup
vtp mode transparent
spanning-tree mode rapid-pvst

! SSH konfigurering
! ip domain-name aurora-local
! crypto key generate rsa modulus 2048
! ip ssh version 2
! line vty 0 4
! transport input ssh
! login local
! exec-timeout 10 0
! exit

! aaa new-model
! Lokala användare
! username NAdmin privilege 15 secret 111
! username SAdmin privilege 7 secret 222
! aaa authentication login default local
! aaa authorization exec default local

vlan 5
 name DMZ
vlan 10
 name MANAGEMENT_TRANSIT
vlan 99
 name NATIVE_VLAN
vlan 999
 name BLACKHOLE

! DMZ on VLAN 5
interface Vlan5
 ip address 10.10.5.11 255.255.255.0
 ipv6 address 2001:DB8:ABCD:5::11/64
 ipv6 address FE80::11 link-local
 no shut
 ip default-gateway 10.10.5.1

! Management on VLAN 10
interface Vlan10
 ip address 10.10.10.11 255.255.255.0
 ipv6 address 2001:DB8:ABCD:10::11/64
 ipv6 address FE80::11 link-local
 no shut
 ip default-gateway 10.10.10.1

! R1
interface Gi1/0/15
 description to_R1_G0/0/1
 switchport mode trunk
 switchport trunk native vlan 99
 switchport trunk allowed vlan 5,10,99
 spanning-tree portfast trunk

! R2
interface Gi1/0/16
 description to_R2_G0/0/0
 switchport mode trunk
 switchport trunk native vlan 99
 switchport trunk allowed vlan 10,99

! R3 
interface Gi1/0/17
 description to_R3_G0/0/0
 switchport mode trunk
 switchport trunk native vlan 99
 switchport trunk allowed vlan 10,99

! FTP i DMZ (access VLAN 5)
interface Gi1/0/1
 description FTP_DMZ
 switchport mode access
 switchport access vlan 5
 spanning-tree portfast

! BLACKHOLE PORTAR
interface range g1/0/2-14,g1/0/18-24
 desc BLACKHOLE
 switchport mode access
 switchport access vlan 999
 shutdown
end


## SW2
conf t
hostname SW2-HK
no ip domain-lookup
vtp mode transparent
spanning-tree mode rapid-pvst

! SSH konfigurering
! ip domain-name aurora-local
! crypto key generate rsa modulus 2048
! ip ssh version 2
! line vty 0 4
! transport input ssh
! login local
! exec-timeout 10 0
! exit

! aaa new-model
! Lokala användare
! username NAdmin privilege 15 secret 111
! username SAdmin privilege 7 secret 222
! aaa authentication login default local
! aaa authorization exec default local

vlan 15
 name MANAGEMENT_INTERNAL
vlan 20
 name Konferens
vlan 25
 name Konferens_AP
vlan 30
 name Kontor
vlan 35
 name Kontor_AP
vlan 40
 name Server
vlan 99
 name Native
vlan 999
 name BLACKHOLE

! Management SVI
interface Vlan15
 ip address 10.10.15.12 255.255.255.0
 ipv6 address 2001:DB8:ABCD:15::12/64
 ipv6 address FE80::12 link-local
 no shut
 ip default-gateway 10.10.15.1

! Trunk till R2
interface Gi1/0/15
 description trunk_to_R2_G0/0/1
 switchport mode trunk
 switchport trunk allowed vlan 15,20,25,30,35,40,99

! Trunk till SW3
interface range Gi1/0/21-22
 description trunk_to_SW3
 switchport mode trunk
 switchport trunk allowed vlan 15,20,25,30,35,40,99

! Trunk till SW4
interface range Gi1/0/23-24
 description trunk_to_SW4
 switchport mode trunk
 switchport trunk allowed vlan 15,20,25,30,35,40,99

! Access SERVER_ROOM
interface range Gi1/0/1-4
 description SERVER_ROOM
 switchport mode access
 switchport access vlan 40
 spanning-tree portfast
 spanning-tree bpduguard enable

! Portar till BLACKHOLE
interface range G1/0/5-14,G1/0/16-20,G1/0/24-28
 desc BLACKHOLE
 switchport mode access
 switchport access vlan 999
 shutdown
end

## SW3
conf t
hostname SW3-HK
no ip domain-lookup
vtp mode transparent
spanning-tree mode rapid-pvst

! SSH konfigurering
! ip domain-name aurora-local
! crypto key generate rsa modulus 2048
! ip ssh version 2
! line vty 0 4
! transport input ssh
! login local
! exec-timeout 10 0
! exit

! aaa new-model
! Lokala användare
! username NAdmin privilege 15 secret 111
! username SAdmin privilege 7 secret 222
! aaa authentication login default local
! aaa authorization exec default local

vlan 15
 name MANAGEMENT_INTERNAL
vlan 20
 name Konferens
vlan 25
 name Konferens_AP
vlan 30
 name Kontor
vlan 35
 name Kontor_AP
vlan 40
 name Server
vlan 99
 name Native
vlan 999
 name BLACKHOLE

! Management SVI
interface Vlan15
 ip address 10.10.15.13 255.255.255.0
 ipv6 address 2001:DB8:ABCD:15::13/64
 ipv6 address FE80::13 link-local
 no shut
 ip default-gateway 10.10.15.1

! Trunk till R3
interface Gi1/0/15
 description trunk_to_R3_G0/0/1
 switchport mode trunk
 switchport trunk allowed vlan 15,20,25,30,35,40,99

! Trunk till SW2
interface range Gi1/0/21-22
 description trunk_to_SW2
 switchport mode trunk
 switchport trunk allowed vlan 15,20,25,30,35,40,99

! Trunk till SW4
interface range Gi1/0/23-24
 description trunk_to_SW4
 switchport mode trunk
 switchport trunk allowed vlan 15,20,25,30,35,40,99

! Konferens-PC VLAN 20
interface Gi1/0/1
 description KONFERENS_PC
 switchport mode access
 switchport access vlan 20
 spanning-tree portfast
 spanning-tree bpduguard enable

! AP1 VLAN 25
interface Gi1/0/16
 description AP1_KONFERENS_GAST
 switchport mode access
 switchport access vlan 25
 spanning-tree portfast
 spanning-tree bpduguard enable

! BLACKHOLE
interface range g1/0/2-14,g1/0/17-20,g1/0/24-28
 desc BLACKHOLE
 switchport mode access
 switchport access vlan 999
 shutdown
end

## SW4
conf t
hostname SW4-HK
no ip domain-lookup
vtp mode transparent
spanning-tree mode rapid-pvst

! SSH konfigurering
! ip domain-name aurora-local
! crypto key generate rsa modulus 2048
! ip ssh version 2
! line vty 0 4
! transport input ssh
! login local
! exec-timeout 10 0
! exit

! aaa new-model
! Lokala användare
! username NAdmin privilege 15 secret 111
! username SAdmin privilege 7 secret 222
! aaa authentication login default local
! aaa authorization exec default local

vlan 15
 name MANAGEMENT_INTERNAL
vlan 20
 name Konferens
vlan 25
 name Konferens_AP
vlan 30
 name Kontor
vlan 35
 name Kontor_AP
vlan 40
 name Server
vlan 99
 name Native
vlan 999
 name BLACKHOLE

! Management SVI
interface Vlan15
 ip address 10.10.15.14 255.255.255.0
 ipv6 address 2001:DB8:ABCD:15::14/64
 ipv6 address FE80::14 link-local
 no shut
 ip default-gateway 10.10.15.1

! Trunk till SW2
interface range Gi1/0/21-22
 description trunk_to_SW2
 switchport mode trunk
 switchport trunk allowed vlan 15,20,25,30,35,40,99

! Trunk till SW3
interface range Gi1/0/23-24
 description trunk_to_SW3
 switchport mode trunk
 switchport trunk allowed vlan 15,20,25,30,35,40,99

! Kontor-PC VLAN 30
interface range Gi1/0/1-14
 description KONTOR_PC
 switchport mode access
 switchport access vlan 30
 spanning-tree portfast
 spanning-tree bpduguard enable

! AP2 VLAN 35
interface Gi1/0/15
 description AP2_KONTOR_WIFI
 switchport mode access
 switchport access vlan 35
 spanning-tree portfast
 spanning-tree bpduguard enable

! BLACKHOLE
interface range G1/0/16-20, G1/0/24-28
 desc BLACKHOLE
 switchport mode access
 switchport access vlan 999
 shutdown
end
