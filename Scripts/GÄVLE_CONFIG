ip dhcp excluded-address 172.16.20.201 172.16.20.254
ip dhcp excluded-address 10.10.25.1 10.10.25.50
ip dhcp excluded-address 10.10.25.201 10.10.25.254
ip dhcp excluded-address 172.16.30.1 172.16.30.50
ip dhcp excluded-address 172.16.30.201 172.16.30.254
ip dhcp excluded-address 10.10.35.1 10.10.35.50
ip dhcp excluded-address 10.10.35.201 10.10.35.254

