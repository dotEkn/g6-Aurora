enable
conf t
crypto isakmp policy 1
encryption aes
hash sha
authentication pre-share
group 5
exit

crypto isakmp key AURORAKEY address 203.0.113.10

crypto ipsec transform-set IPCiscoSet esp-aes esp-sha-hmac
exit
ip access-list extended AURORAVPN
permit ip 10.10.0.0 0.0.0.255 172.16.0.0 0.0.0.255
permit ip 172.16.0.0 0.0.0.255 10.10.0.0 0.0.0.255
exit

crypto map AURORAMAP 5 ipsec-isakmp
set peer 203.0.113.10
set transform-set IPCiscoSet
match address AURORAVPN













conf t

! 1. IPsec inställningar
crypto isakmp policy 1
 encryption aes
 hash sha256
 authentication pre-share
 group 14
 exit

crypto isakmp key AURORAKEY address 203.0.113.10

crypto ipsec transform-set IPCiscoSet esp-aes esp-sha256-hmac
 exit

! 2. Rensa gammal ACL
no ip access-list extended AURORAVPN

! 3. Komplett ACL: SPEGELVÄND! Från GÄVLE till FALUN
ip access-list extended AURORAVPN
 ! Gävle Mgmt (99, 10, 15) till Falun Mgmt (199, 105)
 permit ip 10.10.99.0 0.0.0.255 10.10.199.0 0.0.0.255
 permit ip 10.10.10.0 0.0.0.255 10.10.199.0 0.0.0.255
 permit ip 10.10.15.0 0.0.0.255 10.10.199.0 0.0.0.255
 permit ip 10.10.99.0 0.0.0.255 10.10.105.0 0.0.0.255
 ! Gävle Server/DMZ (40, 5) till Falun Server (140)
 permit ip 10.10.40.0 0.0.0.255 10.10.140.0 0.0.0.255
 permit ip 10.10.5.0 0.0.0.255 10.10.140.0 0.0.0.255
 ! Gävle Server (40) till Falun Personal/Analys (172.16.110, 172.16.120)
 permit ip 10.10.40.0 0.0.0.255 172.16.110.0 0.0.0.255
 permit ip 10.10.40.0 0.0.0.255 172.16.120.0 0.0.0.255
 ! Gävle Kontor (172.16.30) till Falun Personal/Analys
 permit ip 172.16.30.0 0.0.0.255 172.16.110.0 0.0.0.255
 permit ip 172.16.30.0 0.0.0.255 172.16.120.0 0.0.0.255
 ! R1-R2-R3 länknät från Gävle
 permit ip 10.10.99.0 0.0.0.255 10.10.1.0 0.0.0.255
 exit

! 4. Applicera Crypto map
crypto map AURORAMAP 5 ipsec-isakmp
 set peer 203.0.113.10
 set transform-set IPCiscoSet
 match address AURORAVPN
 exit

interface GigabitEthernet0/0/0
 crypto map AURORAMAP
 exit









enable
conf t

! 1. Ta bort den gamla NAT-kopplingen
no ip nat inside source list 5 interface GigabitEthernet0/0/0 overload

! 2. Skapa den nya, smarta NAT-listan
ip access-list extended HK-NAT-EXT

 ! --- STEG A: NAT-UNDANTAG FÖR VPN (Deny = Gör INGEN NAT) ---
 ! Detta stoppar NAT från att stjäla trafik som går mellan Falun och Gävle
 deny ip 10.10.0.0 0.0.255.255 10.10.0.0 0.0.255.255
 deny ip 10.10.0.0 0.0.255.255 172.16.0.0 0.15.255.255
 deny ip 172.16.0.0 0.15.255.255 10.10.0.0 0.0.255.255
 deny ip 172.16.0.0 0.15.255.255 172.16.0.0 0.15.255.255

 ! --- STEG B: TILLÅT NAT TILL INTERNET (Permit = Översätt till publik IP) ---
 ! Här lägger vi in exakt samma nätverk som du hade i din gamla access-list 5
 permit ip 10.10.5.0 0.0.0.255 any
 permit ip 10.10.40.0 0.0.0.255 any
 permit ip 10.10.99.0 0.0.0.255 any
 permit ip 172.16.20.0 0.0.0.255 any
 permit ip 172.16.25.0 0.0.0.255 any
 permit ip 172.16.30.0 0.0.0.255 any
 permit ip 172.16.35.0 0.0.0.255 any
 exit

! 3. Aktivera den nya NAT-regeln på ditt WAN-interface
ip nat inside source list HK-NAT-EXT interface GigabitEthernet0/0/0 overload
exit

! 4. Rensa minnet från gamla, felaktiga NAT-översättningar (Superviktigt!)
clear ip nat translation *
